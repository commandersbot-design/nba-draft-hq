{
  "name": "nba-draft-hq",
  "version": "1.0.0",
  "description": "NBA Draft HQ - 2026 Big Board and Mock Draft",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node scripts/init-db.js",
    "platform:migrate": "node scripts/platform/apply-platform-migration.js",
    "platform:seed": "node scripts/platform/seed-platform-vocabularies.js",
    "db:migrate:ingestion": "node scripts/ingestion/migrate-ingestion.js",
    "ingest:seed-prospects": "node scripts/ingestion/seed-prospects.js",
    "ingest:sync": "node scripts/ingestion/sync-all.js",
    "ingest:transform": "node scripts/ingestion/transform.js",
    "ingest:export": "node scripts/ingestion/export-profile-stats.js",
    "ingest:cbbd": "node scripts/platform/run-cbbd-connector.js",
    "ingest:nba": "node scripts/platform/run-nba-combine-connector.js",
    "ingest:historical:sync": "node scripts/ingestion/sync-historical-prospects.js",
    "ingest:historical:transform": "node scripts/ingestion/transform-historical-prospects.js",
    "ingest:historical:export": "node scripts/ingestion/export-historical-prospects.js",
    "ingest:historical:coverage:export": "node scripts/ingestion/export-historical-coverage.js",
    "ingest:historical": "npm run ingest:historical:sync && npm run ingest:historical:transform && npm run ingest:historical:export",
    "ingest:historical:sources:sync": "node scripts/ingestion/sync-historical-sources.js",
    "ingest:historical:sources:normalize": "node scripts/ingestion/normalize-historical-sources.js",
    "ingest:historical:sources": "npm run ingest:historical:sources:sync && npm run ingest:historical:sources:normalize",
    "ingest:historical:sources:status": "node scripts/ingestion/inspect-historical-upstream.js",
    "ingest:historical:bootstrap": "node scripts/ingestion/bootstrap-historical-sources.js",
    "ingest:historical:derived": "node scripts/ingestion/derive-historical-features.js",
    "ingest:historical:derived:export": "node scripts/ingestion/export-historical-derived.js",
    "ingest:historical:full": "npm run ingest:historical:bootstrap && npm run ingest:historical:sources && npm run ingest:historical:derived && npm run ingest:historical:derived:export && npm run ingest:historical:coverage:export && npm run ingest:historical:sources:status",
    "import:csv": "node scripts/platform/import-vendor-csv.js",
    "validate:data": "node scripts/platform/validate-platform-data.js",
    "inspect:coverage": "node scripts/platform/inspect-player-coverage.js",
    "inspect:provenance": "node scripts/platform/inspect-provenance.js",
    "inspect:ingestion": "node scripts/platform/inspect-ingestion-status.js",
    "platform:api": "node scripts/platform/run-platform-api.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
